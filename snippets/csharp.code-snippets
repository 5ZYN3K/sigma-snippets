    "            {",
    "                znaleziono = false;",
    "                break;",
    "            }",
    "        }",
    "",
    "        if (znaleziono)",
    "            return true;",
    "    }",
    "",
    "    return false;",
    "}",
    "",
    "// Przykład",
    "string tekst = \"Ala ma kota\";",
    "string wzorzec = \"kot\";",
    "",
    "bool wynik = ZnajdzWzorzec(tekst, wzorzec);",
