    "    static string Szyfruj(string tekst)",
    "    {",
    "        string klucz = \"GADERYPOLUKI\";",
    "        char[] wynik = tekst.ToCharArray();",
    "",
    "        for (int i = 0; i < wynik.Length; i++)",
    "        {",
    "            char znak = Char.ToUpper(wynik[i]);",
    "",
    "            int index = klucz.IndexOf(znak);",
    "",
    "            if (index != -1)",
    "            {",
    "                if (index % 2 == 0)",
    "                    wynik[i] = klucz[index + 1];",
    "                else",
    "                    wynik[i] = klucz[index - 1];",
    "            }",
    "        }",
    "",
    "        return new string(wynik);",
    "    }",
    "",
    "    static void Main()",
    "    {",
    "        Console.Write(\"Podaj tekst: \");",
    "        string tekst = Console.ReadLine();",
    "",
    "        string zaszyfrowany = Szyfruj(tekst);",
    "",
    "        Console.WriteLine(\"Zaszyfrowany tekst: \" + zaszyfrowany);",
    "    }",
    "}"
