   "Sito Eratostenesa": {
    "scope": "csharp",
    "prefix": "^sitolist",
    "body": [
      "//Złożoność: O(n log log n)",
      "public List<int> SitoEratostenesa(int n) //znajdowanie liczb pierwszych",
      "{",
      "    bool[] czyPierwsza = new bool[n + 1];",
      "",
      "    //zakładamy, że wszystkie liczby są pierwsze",
      "    for (int i = 2; i <= n; i++)",
      "    {",
      "        czyPierwsza[i] = true;",
      "    }",
      "",
      "    for (int i = 2; i * i <= n; i++)",
      "    {",
      "        if (czyPierwsza[i])",
      "        {",
      "            //oznaczanie wielokrotności jako niepierwsze",
      "            for (int j = i * i; j <= n; j += i)",
      "            {",
      "                czyPierwsza[j] = false;",
      "            }",
      "        }",
      "    }",
      "",
      "    List<int> liczbyPierwsze = new List<int>();",
      "",
      "    for (int i = 2; i <= n; i++)",
      "    {",
      "        if (czyPierwsza[i])",
      "        {",
      "            liczbyPierwsze.Add(i);",
      "        }",
      "    }",
      "",
      "    return liczbyPierwsze;",
      "}"
    ],
    "description": "Sito Eratostenesa - lista"
  },
