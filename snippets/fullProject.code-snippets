    "DaneOsoboweReact": {
        "scope": "javascript,javascriptreact",
        "prefix": "DaneOsoboweReact",
        "body": [
            "import { useState } from \"react\";",
            "",
            "export default function NewFormComponent() {",
            "    const [imie, setImie] = useState(\"\");",
            "    const [nazwisko, setNazwisko] = useState(\"\");",
            "    const [wiek, setWiek] = useState(0);",
            "    const [email, setEmail] = useState(\"\");",
            "    const [list, setList] = useState([]);",
            "    const [error, setError] = useState(\"\");",
            "    const [editId, setEditId] = useState(null);",
            "    const [sortBy, setSortBy] = useState(null);",
            "    const [sortOrder, setSortOrder] = useState(\"asc\");",
            "",
            "    const handleSubmit = (e) => {",
            "        e.preventDefault();",
            "",
            "        if (editId !== null) {",
            "            const newList = list.map((czlowiek) => {",
            "                if (czlowiek.id == editId) {",
            "                    return {",
            "                        ...czlowiek,",
            "                        firstName: imie,",
            "                        lastName: nazwisko,",
            "                        age: wiek,",
            "                        email: email,",
            "                    };",
            "                } else {",
            "                    return czlowiek;",
            "                }",
            "            });",
            "",
            "            setList(newList);",
            "            setEditId(null);",
            "            czyscFormularz();",
            "            setError(\"\");",
            "        } else {",
            "",
            "            if (imie == \"\" || imie == null) {",
            "                setError(\"Błąd! Podaj imię\");",
            "                return;",
            "            }",
            "",
            "            if (nazwisko == \"\" || nazwisko == null) {",
            "                setError(\"Błąd! Podaj nazwisko\");",
            "                return;",
            "            }",
            "",
            "            if (wiek <= 0) {",
            "                setError(\"Błąd! Podaj poprawny wiek\");",
            "                return;",
            "            }",
            "",
            "            if (email == \"\" || email == null) {",
            "                setError(\"Błąd! Podaj email\");",
            "                return;",
            "            }",
            "",
            "            const newPerson = {",
            "                id: Date.now(),",
            "                firstName: imie,",
            "                lastName: nazwisko,",
            "                age: wiek,",
            "                email: email,",
            "            };",
            "",
            "            setList([...list, newPerson]);",
            "",
            "            czyscFormularz();",
            "            setError(\"\");",
            "        }",
            "    };",
            "",
            "    const usun = (id) => {",
            "        setList(list.filter((o) => o.id !== id));",
            "    };",
            "",
            "    const edytuj = (id) => {",
            "        const osobaDoEdycji = list.find((o) => o.id == id);",
            "",
            "        if (!osobaDoEdycji) return;",
            "",
            "        setImie(osobaDoEdycji.firstName);",
            "        setNazwisko(osobaDoEdycji.lastName);",
            "        setWiek(osobaDoEdycji.age);",
            "        setEmail(osobaDoEdycji.email);",
            "        setEditId(id);",
            "    };",
            "",
            "    const czyscFormularz = () => {",
            "        setImie(\"\");",
            "        setNazwisko(\"\");",
            "        setWiek(\"\");",
            "        setEmail(\"\");",
            "    };",
            "",
            "    const sortList = (key) => {",
            "",
            "        let order = sortOrder;",
            "",
            "        if (sortBy === key) {",
            "",
            "            if (sortOrder === \"asc\") {",
            "                order = \"desc\";",
            "            } else {",
            "                order = \"asc\";",
            "            }",
            "",
            "            setSortOrder(order);",
            "",
            "        } else {",
            "",
            "            setSortBy(key);",
            "            setSortOrder(\"asc\");",
            "            order = \"asc\";",
            "        }",
            "",
            "        const sorted = [...list].sort((a, b) => {",
            "",
            "            if (a[key] < b[key]) {",
            "",
            "                if (order === \"asc\") {",
            "                    return -1;",
            "                } else {",
            "                    return 1;",
            "                }",
            "            }",
            "",
            "            if (a[key] > b[key]) {",
            "",
            "                if (order === \"asc\") {",
            "                    return 1;",
            "                } else {",
            "                    return -1;",
            "                }",
            "            }",
            "",
            "            return 0;",
            "        });",
            "",
            "        setList(sorted);",
            "    };",
            "",
            "    return (",
            "",
            "        // container -> dodaje marginesy i centruje zawartość",
            "        <div className=\"container mt-5\">",
            "",
            "            {/* row -> bootstrapowy wiersz */}",
            "            <div className=\"row justify-content-center\">",
            "",
            "                {/* col-md-8 -> szerokość kolumny na średnich ekranach */}",
            "                <div className=\"col-md-8\">",
            "",
            "                    {/* card -> gotowa karta bootstrapa */}",
            "                    <div className=\"card shadow\">",
            "",
            "                        {/* card-body -> padding wewnątrz karty */}",
            "                        <div className=\"card-body\">",
            "",
            "                            {/* text-center -> wyśrodkowanie tekstu */}",
            "                            <h2 className=\"text-center mb-4\">",
            "                                Formularz osób",
            "                            </h2>",
            "",
            "                            <form onSubmit={handleSubmit}>",
            "",
            "                                {/* mb-3 -> margin bottom */}",
            "                                <div className=\"mb-3\">",
            "",
            "                                    {/* form-label -> styl label z bootstrapa */}",
            "                                    <label htmlFor=\"imie\" className=\"form-label\">",
            "                                        Podaj imię:",
            "                                    </label>",
            "",
            "                                    {/* form-control -> stylowany input bootstrapa */}",
            "                                    <input",
            "                                        type=\"text\"",
            "                                        id=\"imie\"",
            "                                        className=\"form-control\"",
            "                                        value={imie}",
            "                                        onChange={(e) => setImie(e.target.value)}",
            "                                    />",
            "                                </div>",
            "",
            "                                <div className=\"mb-3\">",
            "",
            "                                    <label htmlFor=\"nazwisko\" className=\"form-label\">",
            "                                        Podaj nazwisko:",
            "                                    </label>",
            "",
            "                                    <input",
            "                                        type=\"text\"",
            "                                        id=\"nazwisko\"",
            "                                        className=\"form-control\"",
            "                                        value={nazwisko}",
            "                                        onChange={(e) => setNazwisko(e.target.value)}",
            "                                    />",
            "                                </div>",
            "",
            "                                <div className=\"mb-3\">",
            "",
            "                                    <label htmlFor=\"wiek\" className=\"form-label\">",
            "                                        Podaj swój wiek:",
            "                                    </label>",
            "",
            "                                    <input",
            "                                        type=\"number\"",
            "                                        id=\"wiek\"",
            "                                        className=\"form-control\"",
            "                                        value={wiek}",
            "                                        onChange={(e) => setWiek(e.target.value)}",
            "                                    />",
            "                                </div>",
            "",
            "                                <div className=\"mb-3\">",
            "",
            "                                    <label htmlFor=\"email\" className=\"form-label\">",
            "                                        Podaj email:",
            "                                    </label>",
            "",
            "                                    <input",
            "                                        type=\"email\"",
            "                                        id=\"email\"",
            "                                        className=\"form-control\"",
            "                                        value={email}",
            "                                        onChange={(e) => setEmail(e.target.value)}",
            "                                    />",
            "                                </div>",
            "",
            "                                {/* alert alert-danger -> czerwony komunikat błędu */}",
            "                                {error && (",
            "                                    <div className=\"alert alert-danger\">",
            "                                        {error}",
            "                                    </div>",
            "                                )}",
            "",
            "                                {/* d-grid -> button na całą szerokość */}",
            "                                <div className=\"d-grid\">",
            "",
            "                                    {/* btn -> styl przycisku",
            "                                        btn-primary -> niebieski przycisk */}",
            "                                    <button",
            "                                        type=\"submit\"",
            "                                        className=\"btn btn-primary\"",
            "                                    >",
            "                                        {editId !== null && \"Zapisz zmiany\"}",
            "                                        {editId === null && \"Wyślij\"}",
            "                                    </button>",
            "                                </div>",
            "                            </form>",
            "                        </div>",
            "                    </div>",
            "",
            "                    {/* mt-5 -> większy odstęp od góry */}",
            "                    <div className=\"mt-5\">",
            "",
            "                        <h2 className=\"mb-3\">",
            "                            Lista osób:",
            "                        </h2>",
            "",
            "                        {/* table -> tabela bootstrapa",
            "                            table-striped -> paski",
            "                            table-hover -> hover na wierszach */}",
            "                        <table className=\"table table-striped table-hover\">",
            "",
            "                            {/* table-dark -> ciemny header */}",
            "                            <thead className=\"table-dark\">",
            "",
            "                                <tr>",
            "",
            "                                    {/* cursor pointer inline style */}",
            "                                    <th",
            "                                        style={{ cursor: \"pointer\" }}",
            "                                        onClick={() => sortList(\"firstName\")}",
            "                                    >",
            "                                        Imię",
            "                                    </th>",
            "",
            "                                    <th",
            "                                        style={{ cursor: \"pointer\" }}",
            "                                        onClick={() => sortList(\"lastName\")}",
            "                                    >",
            "                                        Nazwisko",
            "                                    </th>",
            "",
            "                                    <th",
            "                                        style={{ cursor: \"pointer\" }}",
            "                                        onClick={() => sortList(\"age\")}",
            "                                    >",
            "                                        Wiek",
            "                                    </th>",
            "",
            "                                    <th",
            "                                        style={{ cursor: \"pointer\" }}",
            "                                        onClick={() => sortList(\"email\")}",
            "                                    >",
            "                                        Email",
            "                                    </th>",
            "",
            "                                    <th>",
            "                                        Akcje",
            "                                    </th>",
            "                                </tr>",
            "                            </thead>",
            "",
            "                            <tbody>",
            "",
            "                                {list.map((osobnik) => (",
            "",
            "                                    <tr key={osobnik.id}>",
            "",
            "                                        <td>{osobnik.firstName}</td>",
            "                                        <td>{osobnik.lastName}</td>",
            "                                        <td>{osobnik.age}</td>",
            "                                        <td>{osobnik.email}</td>",
            "",
            "                                        <td>",
            "",
            "                                            {/* btn-warning -> żółty button",
            "                                                btn-sm -> mały button */}",
            "                                            <button",
            "                                                className=\"btn btn-warning btn-sm me-2\"",
            "                                                onClick={() => edytuj(osobnik.id)}",
            "                                            >",
            "                                                Edytuj",
            "                                            </button>",
            "",
            "                                            {/* btn-danger -> czerwony button */}",
            "                                            <button",
            "                                                className=\"btn btn-danger btn-sm\"",
            "                                                onClick={() => usun(osobnik.id)}",
            "                                            >",
            "                                                Usuń",
            "                                            </button>",
            "",
            "                                        </td>",
            "                                    </tr>",
            "                                ))}",
            "",
            "                            </tbody>",
            "                        </table>",
            "                    </div>",
            "                </div>",
            "            </div>",
            "        </div>",
            "    );",
            "}"
        ],
        "description": "React formularz danych osobowych z CRUD, walidacją i sortowaniem"
    },
