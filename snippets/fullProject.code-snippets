"MAUI Quiz 2026 C#": {
  "scope": "csharp",
  "prefix": "QUIZ2026CS",
  "body": [
    "using System;",
    "using Microsoft.Maui.Controls;",
    "",
    "namespace Quiz",
    "{",
    "    public partial class MainPage : ContentPage",
    "    {",
    "        // =========================",
    "        // KLASA BAZOWA",
    "        // =========================",
    "        public abstract class Pytanie",
    "        {",
    "            protected string _trescPytania;",
    "            protected string _nazwaZdjecia;",
    "",
    "            public string TrescPytania => _trescPytania;",
    "            public string NazwaZdjecia => _nazwaZdjecia;",
    "",
    "            public Pytanie(string trescPytania, string nazwaZdjecia)",
    "            {",
    "                _trescPytania = trescPytania;",
    "                _nazwaZdjecia = nazwaZdjecia;",
    "            }",
    "",
    "            public abstract bool SprawdzenieOdpowiedzi(string odpowiedz);",
    "        }",
    "",
    "        // =========================",
    "        // PYTANIE ZAMKNIĘTE",
    "        // =========================",
    "        public class PytanieZamkniete : Pytanie",
    "        {",
    "            private string _odpowiedzA;",
    "            private string _odpowiedzB;",
    "            private string _odpowiedzC;",
    "",
    "            private string _prawidlowaOdpowiedz;",
    "",
    "            public string OdpowiedzA => _odpowiedzA;",
    "            public string OdpowiedzB => _odpowiedzB;",
    "            public string OdpowiedzC => _odpowiedzC;",
    "",
    "            public PytanieZamkniete(",
    "                string trescPytania,",
    "                string nazwaZdjecia,",
    "                string odpowiedzA,",
    "                string odpowiedzB,",
    "                string odpowiedzC,",
    "                string prawidlowaOdpowiedz)",
    "                : base(trescPytania, nazwaZdjecia)",
    "            {",
    "                _odpowiedzA = odpowiedzA;",
    "                _odpowiedzB = odpowiedzB;",
