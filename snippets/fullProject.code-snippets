{
    "MediaShopXaml": {
        "scope": "xml,xaml",
        "prefix": "MediaShopXaml",
        "body": [
            "<?xml version=\"1.0\" encoding=\"utf-8\" ?>",
            "<ContentPage xmlns=\"http://schemas.microsoft.com/dotnet/2021/maui\"",
            "             xmlns:x=\"http://schemas.microsoft.com/winfx/2009/xaml\"",
            "             x:Class=\"MediaShop.MainPage\"",
            "             BackgroundColor=\"#F2F4F8\">",
            "",
            "    <ScrollView>",
            "        <VerticalStackLayout",
            "            Padding=\"24\"",
            "            Spacing=\"20\">",
            "",
            "            <Label",
            "                Text=\"Dodaj nowe media\"",
            "                FontSize=\"28\"",
            "                FontAttributes=\"Bold\"",
            "                TextColor=\"#1E293B\"",
            "                HorizontalOptions=\"Center\" />",
            "",
            "            <Border",
            "                BackgroundColor=\"White\"",
            "                Padding=\"18\"",
            "                StrokeShape=\"RoundRectangle 18\">",
            "",
            "                <VerticalStackLayout Spacing=\"18\">",
            "",
            "                    <!-- Tytuł -->",
            "                    <Grid ColumnSpacing=\"12\">",
            "                        <Grid.ColumnDefinitions>",
            "                            <ColumnDefinition Width=\"*\" />",
            "                            <ColumnDefinition Width=\"*\" />",
            "                        </Grid.ColumnDefinitions>",
            "",
            "                        <VerticalStackLayout Spacing=\"6\">",
            "                            <Label",
            "                                Text=\"Tytuł produktu\"",
            "                                FontAttributes=\"Bold\"",
            "                                TextColor=\"#334155\" />",
            "",
            "                            <Entry",
            "                                Placeholder=\"Wpisz tytuł\"",
            "                                BackgroundColor=\"#F8FAFC\"",
            "                                Text=\"{Binding NewProduct.Name, Mode=TwoWay}\"/>",
            "                        </VerticalStackLayout>",
            "",
            "                        <VerticalStackLayout",
            "                            Grid.Column=\"1\"",
            "                            Spacing=\"6\">",
            "",
            "                            <Label",
            "                                Text=\"Podgląd tytułu\"",
            "                                FontAttributes=\"Bold\"",
            "                                TextColor=\"#334155\" />",
            "",
            "                            <Label",
            "                                Text=\"{Binding NewProduct.Name}\"",
            "                                BackgroundColor=\"#F8FAFC\"",
            "                                Padding=\"12\"",
            "                                TextColor=\"#64748B\" />",
            "                        </VerticalStackLayout>",
            "                    </Grid>",
            "",
            "                    <!-- Autor -->",
            "                    <Grid ColumnSpacing=\"12\">",
            "                        <Grid.ColumnDefinitions>",
            "                            <ColumnDefinition Width=\"*\" />",
            "                            <ColumnDefinition Width=\"*\" />",
            "                        </Grid.ColumnDefinitions>",
            "",
            "                        <VerticalStackLayout Spacing=\"6\">",
            "                            <Label",
            "                                Text=\"Autor / Twórca\"",
            "                                FontAttributes=\"Bold\"",
            "                                TextColor=\"#334155\" />",
            "",
            "                            <Entry",
            "                                Placeholder=\"Wpisz autora\"",
            "                                BackgroundColor=\"#F8FAFC\"",
            "                                Text=\"{Binding NewProduct.Author, Mode=TwoWay}\"/>",
            "                        </VerticalStackLayout>",
            "",
            "                        <VerticalStackLayout",
            "                            Grid.Column=\"1\"",
            "                            Spacing=\"6\">",
            "",
            "                            <Label",
            "                                Text=\"Podgląd autora\"",
            "                                FontAttributes=\"Bold\"",
            "                                TextColor=\"#334155\" />",
            "",
            "                            <Label",
            "                                Text=\"{Binding NewProduct.Author}\"",
            "                                BackgroundColor=\"#F8FAFC\"",
            "                                Padding=\"12\"",
            "                                TextColor=\"#64748B\" />",
            "                        </VerticalStackLayout>",
            "                    </Grid>",
            "",
            "                    <!-- Typ media -->",
            "                    <VerticalStackLayout Spacing=\"8\">",
            "                        <Label",
            "                            Text=\"Typ media\"",
            "                            FontAttributes=\"Bold\"",
            "                            TextColor=\"#334155\" />",
            "",
            "                        <HorizontalStackLayout Spacing=\"18\">",
            "                            <RadioButton ",
            "                                Content=\"Film\" ",
            "                                GroupName=\"mediaType\" ",
            "                                x:Name=\"film\"",
            "                                CheckedChanged=\"radioBtn_CheckedChanged\"",
            "                            />",
            "                            <RadioButton ",
            "                                Content=\"Książka\" ",
            "                                GroupName=\"mediaType\" ",
            "                                x:Name=\"book\"",
            "                                CheckedChanged=\"radioBtn_CheckedChanged\"",
            "                            />",
            "                            <RadioButton ",
            "                                Content=\"Gra\" ",
            "                                GroupName=\"mediaType\" ",
            "                                x:Name=\"game\"",
            "                                CheckedChanged=\"radioBtn_CheckedChanged\"",
            "                            />",
            "                        </HorizontalStackLayout>",
            "",
            "                        <Label",
            "                            Text=\"{Binding NewProduct.MediaType}\"",
            "                            BackgroundColor=\"#F8FAFC\"",
            "                            Padding=\"12\"",
            "                            TextColor=\"#64748B\" />",
            "                    </VerticalStackLayout>",
            "",
            "                    <!-- CollectionView -->",
            "                    <VerticalStackLayout Spacing=\"8\">",
            "                        <Label",
            "                            Text=\"Gatunek\"",
            "                            FontAttributes=\"Bold\"",
            "                            TextColor=\"#334155\" />",
            "",
            "                        <Border",
            "                            BackgroundColor=\"#F8FAFC\"",
            "                            StrokeShape=\"RoundRectangle 12\"",
            "                            Padding=\"10\"",
            "                        >",
            "",
            "                            <CollectionView ",
            "                                HeightRequest=\"120\" ",
            "                                ItemsSource=\"{Binding GenreList}\"",
            "                            >",
            "                                <CollectionView.ItemTemplate>",
            "                                    <DataTemplate>",
            "                                        <HorizontalStackLayout>",
            "                                            <CheckBox IsChecked=\"{Binding IsGenreChecked}\"/>",
            "                                            <Label ",
            "                                                Text=\"{Binding Name}\" ",
            "                                                VerticalOptions=\"Center\"",
            "                                            />",
            "                                        </HorizontalStackLayout>",
            "                                    </DataTemplate>",
            "                                </CollectionView.ItemTemplate>",
            "                            </CollectionView>",
            "                            ",
            "                        </Border>",
            "                    </VerticalStackLayout>",
            "",
            "                    <!-- Stepper -->",
            "                    <VerticalStackLayout Spacing=\"8\">",
            "                        <Label",
            "                            Text=\"Długość serii\"",
            "                            FontAttributes=\"Bold\"",
            "                            TextColor=\"#334155\" />",
            "",
            "                        <HorizontalStackLayout Spacing=\"12\">",
            "                            <Stepper ",
            "                                Value=\"{Binding NewProduct.Episodes}\"",
            "                                Increment=\"1\"",
            "                            />",
            "",
            "                            <Label",
            "                                Text=\"{Binding NewProduct.Episodes}\"",
            "                                VerticalOptions=\"Center\"",
            "                                TextColor=\"#64748B\" />",
            "                        </HorizontalStackLayout>",
            "                    </VerticalStackLayout>",
            "",
            "                    <!-- Slider -->",
            "                    <VerticalStackLayout Spacing=\"8\">",
            "                        <Label",
            "                            Text=\"Zarobki produktu\"",
            "                            FontAttributes=\"Bold\"",
            "                            TextColor=\"#334155\" />",
            "",
            "                        <Slider ",
            "                            Value=\"{Binding NewProduct.Earnings, Mode=TwoWay}\"",
            "                            Maximum=\"9999999\"",
            "                        />",
            "",
            "                        <Label",
            "                            Text=\"{Binding NewProduct.Earnings}\"",
            "                            TextColor=\"#64748B\" />",
            "                    </VerticalStackLayout>",
            "",
            "                    <Button ",
            "                        Text=\"Dodaj produkt\" ",
            "                        x:Name=\"btnAddProduct\"",
            "                        Clicked=\"btnAddProduct_Clicked\"",
            "                    />",
            "",
            "                    <ListView ",
            "                        ItemsSource=\"{Binding ProductList}\" ",
            "                        HasUnevenRows=\"True\"",
            "                        ItemSelected=\"ListView_ItemSelected\"",
            "                        SeparatorVisibility=\"None\"",
            "                        BackgroundColor=\"Transparent\"",
            "                    >",
            "                        <ListView.ItemTemplate>",
            "                            <DataTemplate>",
            "                                <ViewCell>",
            "                                    <Grid Padding=\"0,8\">",
            "                                        <Grid.ColumnDefinitions>",
            "                                            <ColumnDefinition Width=\"*\" />",
            "                                            <ColumnDefinition Width=\"Auto\" />",
            "                                        </Grid.ColumnDefinitions>",
            "",
            "                                        <!-- Karta produktu -->",
            "                                        <Border",
            "                                            BackgroundColor=\"#F8FAFC\"",
            "                                            StrokeShape=\"RoundRectangle 16\"",
            "                                            Padding=\"14\"",
            "                                            Margin=\"0,0,12,0\"",
            "                                        >",
            "                                            <VerticalStackLayout Spacing=\"4\">",
            "                                                <Label ",
            "                                                    Text=\"{Binding Name}\"",
            "                                                    FontSize=\"18\"",
            "                                                    FontAttributes=\"Bold\"",
            "                                                    TextColor=\"#0F172A\"",
            "                                                />",
            "                                                <Label ",
            "                                                    Text=\"{Binding Author}\"",
            "                                                    TextColor=\"#475569\"",
            "                                                />",
            "                                                <Label ",
            "                                                    Text=\"{Binding MediaType}\"",
            "                                                    TextColor=\"#2563EB\"",
            "                                                    FontAttributes=\"Bold\"",
            "                                                />",
            "                                                <Label ",
            "                                                    Text=\"{Binding GenresText}\"",
            "                                                    TextColor=\"#64748B\"",
            "                                                />",
            "                                                <HorizontalStackLayout Spacing=\"18\">",
            "                                                    <Label ",
            "                                                        Text=\"{Binding Episodes, StringFormat='Odcinki: {0}'}\"",
            "                                                        TextColor=\"#475569\"",
            "                                                    />",
            "                                                    <Label ",
            "                                                        Text=\"{Binding Earnings, StringFormat='Zarobki: {0}'}\"",
            "                                                        TextColor=\"#475569\"",
            "                                                    />",
            "                                                </HorizontalStackLayout>",
            "                                            </VerticalStackLayout>",
            "                                        </Border>",
            "",
            "                                        <!-- Przycisk usuwania -->",
            "                                        <Button",
            "                                            x:Name=\"btnDeleteProduct\"",
            "                                            Grid.Column=\"1\"",
            "                                            Text=\"X\"",
            "                                            WidthRequest=\"42\"",
            "                                            HeightRequest=\"42\"",
            "                                            CornerRadius=\"21\"",
            "                                            BackgroundColor=\"#DC2626\"",
            "                                            TextColor=\"White\"",
            "                                            FontAttributes=\"Bold\"",
            "                                            VerticalOptions=\"Center\"",
            "                                            Clicked=\"btnDeleteProduct_Clicked\"",
            "                                        />",
            "                                    </Grid>",
            "                                </ViewCell>",
            "                            </DataTemplate>",
            "                        </ListView.ItemTemplate>",
            "                    </ListView>",
            "                </VerticalStackLayout>",
            "",
            "            </Border>",
            "",
            "        </VerticalStackLayout>",
            "    </ScrollView>",
            "",
            "</ContentPage>"
        ],
        "description": "Cały XAML projektu MediaShop"
    },
    "MediaShopC#": {
        "scope": "csharp",
        "prefix": "MediaShopC#",
        "body": [
            "using System.Collections.ObjectModel;",
            "using System.ComponentModel;",
            "using System.Runtime.CompilerServices;",
            "",
            "namespace MediaShop",
            "{",
            "    public partial class MainPage : ContentPage, INotifyPropertyChanged",
            "    {",
            "        public ObservableCollection<Genre> GenreList { get; set; }",
            "        private Product _newProduct;",
            "        public Product NewProduct",
            "        {",
            "            get => _newProduct;",
            "            set",
            "            {",
            "                _newProduct = value;",
            "                OnPropertyChanged();",
            "            }",
            "        }",
            "        private ObservableCollection<Product> _productList;",
            "        public ObservableCollection<Product> ProductList",
            "        {",
            "            get => _productList;",
            "            set",
            "            {",
            "                _productList = value;",
            "                OnPropertyChanged();",
            "            }",
            "        }",
            "",
            "        private Product _selectedProduct;",
            "        public Product SelectedProduct",
            "        {",
            "            get => _selectedProduct;",
            "            set",
            "            {",
            "                _selectedProduct = value;",
            "                OnPropertyChanged();",
            "            }",
            "        }",
            "        bool isEdited = false;",
            "",
            "        public MainPage()",
            "        {",
            "            InitializeComponent();",
            "",
            "            GenreList = new ObservableCollection<Genre>()",
            "            {",
            "                new Genre(){ Name = \"Action\" },",
            "                new Genre(){ Name = \"Adventure\" },",
            "                new Genre(){ Name = \"Thriller\" },",
            "                new Genre(){ Name = \"Horror\" },",
            "                new Genre(){ Name = \"Slice of life\" },",
            "                new Genre(){ Name = \"Romantic comedy\" },",
            "            };",
            "            NewProduct = new Product();",
            "            ProductList = new ObservableCollection<Product>();",
            "",
            "            BindingContext = this;",
            "        }",
            "",
            "",
            "        public event PropertyChangedEventHandler PropertyChanged;",
            "        private void OnPropertyChanged([CallerMemberName] string propertyName = null)",
            "        {",
            "            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));",
            "        }",
            "",
            "        //Dynamiczne pobieranie wartości z RadioButtona",
            "        private void radioBtn_CheckedChanged(object sender, CheckedChangedEventArgs e)",
            "        {",
            "            if (e.Value == false)",
            "            {",
            "                return;",
            "            }",
            "",
            "            RadioButton radioButton = sender as RadioButton;",
            "",
            "            if (radioButton == null)",
            "            {",
            "                return;",
            "            }",
            "",
            "            NewProduct.MediaType = radioButton.Content.ToString();",
            "        }",
            "        //DODAWANIE PRODUKTU",
            "        private void btnAddProduct_Clicked(object sender, EventArgs e)",
            "        {",
            "            BuildGenresForNewProduct();",
            "",
            "            if (isEdited == true && SelectedProduct != null)",
            "            {",
            "                SelectedProduct.Name = NewProduct.Name;",
            "                SelectedProduct.Author = NewProduct.Author;",
            "                SelectedProduct.MediaType = NewProduct.MediaType;",
            "                SelectedProduct.ProductGenres = NewProduct.ProductGenres;",
            "                SelectedProduct.GenresText = NewProduct.GenresText;",
            "                SelectedProduct.Episodes = NewProduct.Episodes;",
            "                SelectedProduct.Earnings = NewProduct.Earnings;",
            "",
            "                isEdited = false;",
            "                SelectedProduct = null;",
            "            }",
            "            else",
            "            {",
            "                ProductList.Add(NewProduct);",
            "            }",
            "",
            "            NewProduct = new Product();",
            "",
            "            //czyszczenie checkboxów",
            "            foreach (var genre in GenreList)",
            "            {",
            "                genre.IsGenreChecked = false;",
            "            }",
            "        }",
            "        //KLIKNIĘCIE PRODUKTU NA LIŚCIE",
            "        private void ListView_ItemSelected(object sender, SelectedItemChangedEventArgs e)",
            "        {",
            "            isEdited = true;",
            "            //ustawiam kliknięty produkt jako SelectedProdukt",
            "            SelectedProduct = e.SelectedItem as Product; ",
            "            //Wrzucam do formularza dane klikniętego produktu ",
            "            NewProduct = new Product()",
            "            {",
            "                Name = SelectedProduct.Name,",
            "                Author = SelectedProduct.Author,",
            "                MediaType = SelectedProduct.MediaType,",
            "                ProductGenres = SelectedProduct.ProductGenres,",
            "                GenresText = SelectedProduct.GenresText,",
            "                Episodes = SelectedProduct.Episodes,",
            "                Earnings = SelectedProduct.Earnings,",
            "            };",
            "            ",
            "           ",
            "        }",
            "        private void BuildGenresForNewProduct()",
            "        {",
            "            NewProduct.ProductGenres.Clear();",
            "",
            "            string genresText = \"\";",
            "",
            "            foreach (var genre in GenreList)",
            "            {",
            "                if (genre.IsGenreChecked == true)",
            "                {",
            "                    NewProduct.ProductGenres.Add(genre);",
            "",
            "                    if (genresText == \"\")",
            "                    {",
            "                        genresText = genre.Name;",
            "                    }",
            "                    else",
            "                    {",
            "                        genresText += \", \" + genre.Name;",
            "                    }",
            "                }",
            "            }",
            "",
            "            NewProduct.GenresText = genresText;",
            "        }",
            "        //USUWANIE PRODUKTU",
            "        private void btnDeleteProduct_Clicked(object sender, EventArgs e)",
            "        {",
            "            //pobieram kliknięty przycisk",
            "            Button deleteButton = sender as Button;",
            "            if (deleteButton == null)",
            "            {",
            "                return;",
            "            }",
            "            //W DataTemplate BindingContext przycisku to aktualny produkt z listy",
            "            Product productToDelete = deleteButton.BindingContext as Product;",
            "            if (productToDelete == null)",
            "            {",
            "                return;",
            "            }",
            "            ProductList.Remove(productToDelete);",
            "        }",
            "    }",
            "",
            "    public class Genre : MainViewClass",
            "    {",
            "        private string _name;",
            "        public string Name",
            "        {",
            "            get => _name;",
            "            set",
            "            {",
            "                _name = value;",
            "                OnPropertyChanged();",
            "            }",
            "        }",
            "        private bool _isGenreChecked = false;",
            "        public bool IsGenreChecked",
            "        {",
            "            get => _isGenreChecked;",
            "            set",
            "            {",
            "                _isGenreChecked = value;",
            "                OnPropertyChanged();",
            "            }",
            "        }",
            "        ",
            "    }",
            "    public class Product : MainViewClass",
            "    {",
            "        private string _name;",
            "        public string Name",
            "        {",
            "            get => _name;",
            "            set",
            "            {",
            "                _name = value;",
            "                OnPropertyChanged();",
            "            }",
            "        }",
            "        private string _author;",
            "        public string Author",
            "        {",
            "            get => _author;",
            "            set",
            "            {",
            "                _author = value;",
            "                OnPropertyChanged();",
            "            }",
            "        }",
            "        private string mediaType;",
            "        public string MediaType",
            "        {",
            "            get => mediaType;",
            "            set",
            "            {",
            "                mediaType = value;",
            "                OnPropertyChanged();",
            "            }",
            "        }",
            "        //label oczekuje stringa a nie listy/kolekcji, dlatego trzeba podjąć dużo zabiegów żeby zbudować stringa i to poprawnie wyświetlić ",
            "        public ObservableCollection<Genre> ProductGenres { get; set; } = new ObservableCollection<Genre>();",
            "",
            "        private string _genresText;",
            "        public string GenresText",
            "        {",
            "            get => _genresText;",
            "            set",
            "            {",
            "                _genresText = value;",
            "                OnPropertyChanged();",
            "            }",
            "        }",
            "",
            "        private int _episodes = 1;",
            "        public int Episodes",
            "        {",
            "            get => _episodes;",
            "            set",
            "            {",
            "                _episodes = value;",
            "                OnPropertyChanged();",
            "            }",
            "        }",
            "        private int _earnings;",
            "        public int Earnings",
            "        {",
            "            get => _earnings;",
            "            set",
            "            {",
            "                _earnings = value;",
            "                OnPropertyChanged();",
            "            }",
            "        }",
            "        ",
            "    }",
            "    public class MainViewClass : INotifyPropertyChanged",
            "    {",
            "        public event PropertyChangedEventHandler PropertyChanged;",
            "        protected void OnPropertyChanged([CallerMemberName] string propertyName = null)",
            "        {",
            "            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));",
            "        }",
            "    }",
            "}"
        ],
        "description": "Cały kod C# projektu MediaShop"
    },
    "JobApplicationXaml": {
        "scope": "xml,xaml",
        "prefix": "JobApplicationXaml",
        "body": [
            "<?xml version=\"1.0\" encoding=\"utf-8\" ?>",
            "<ContentPage xmlns=\"http://schemas.microsoft.com/dotnet/2021/maui\"",
            "             xmlns:x=\"http://schemas.microsoft.com/winfx/2009/xaml\"",
            "             x:Class=\"BindingiKontrolki.MainPage\"",
            "             BackgroundColor=\"#F2F4F8\">",
            "",
            "    <ScrollView>",
            "        <VerticalStackLayout Padding=\"24\" Spacing=\"22\">",
            "",
            "            <VerticalStackLayout Spacing=\"4\">",
            "                <Label ",
            "                    Text=\"Job Application Form\"",
            "                    FontSize=\"28\"",
            "                    FontAttributes=\"Bold\"",
            "                    TextColor=\"#1E293B\"",
            "                />",
            "                <Label ",
            "                    Text=\"Fill in your personal details and preferences\"",
            "                    FontSize=\"14\"",
            "                    TextColor=\"#64748B\"",
            "                />",
            "            </VerticalStackLayout>",
            "",
            "            <Border ",
            "                BackgroundColor=\"White\"",
            "                Stroke=\"#E2E8F0\"",
            "                StrokeShape=\"RoundRectangle 18\"",
            "                Padding=\"18\"",
            "            >",
            "                <VerticalStackLayout Spacing=\"18\">",
            "                    <VerticalStackLayout Spacing=\"6\">",
            "                        <Label ",
            "                            Text=\"First name\"",
            "                            FontAttributes=\"Bold\"",
            "                            TextColor=\"#334155\"",
            "                        />",
            "                        <Entry ",
            "                            x:Name=\"inpFirstName\"",
            "                            Placeholder=\"Enter your first name\"",
            "                            BackgroundColor=\"#F8FAFC\"",
            "                            TextColor=\"#0F172A\"",
            "                            PlaceholderColor=\"#94A3B8\"",
            "                            Text=\"{Binding newWorker.FirstName, Mode=TwoWay}\"",
            "                        />",
            "                        <!-- live podgląd wpisywanej treści:-->",
            "                        <Label Text=\"{Binding newWorker.FirstName}\"/>",
            "                    </VerticalStackLayout>",
            "",
            "                    <VerticalStackLayout Spacing=\"6\">",
            "                        <Label ",
            "                            Text=\"Last name\"",
            "                            FontAttributes=\"Bold\"",
            "                            TextColor=\"#334155\"",
            "                        />",
            "                        <Entry ",
            "                            x:Name=\"inpLastName\"",
            "                            Placeholder=\"Enter your last name\"",
            "                            BackgroundColor=\"#F8FAFC\"",
            "                            TextColor=\"#0F172A\"",
            "                            PlaceholderColor=\"#94A3B8\"",
            "                            Text=\"{Binding newWorker.LastName, Mode=TwoWay}\"",
            "                        />",
            "                        <Label Text=\"{Binding newWorker.LastName}\"/>",
            "                    </VerticalStackLayout>",
            "",
            "                    <VerticalStackLayout Spacing=\"6\">",
            "                        <Label ",
            "                            Text=\"Position\"",
            "                            FontAttributes=\"Bold\"",
            "                            TextColor=\"#334155\"",
            "                        />",
            "                        <Picker ",
            "                            x:Name=\"pickerPositions\"",
            "                            Title=\"Select position\"",
            "                            BackgroundColor=\"#F8FAFC\"",
            "                            TextColor=\"#0F172A\"",
            "                            TitleColor=\"#94A3B8\"",
            "                            ItemsSource=\"{Binding Positions}\"",
            "                            SelectedItem=\"{Binding newWorker.Position, Mode=TwoWay}\"",
            "                        >",
            "",
            "                        </Picker>",
            "                    </VerticalStackLayout>",
            "",
            "                    <VerticalStackLayout Spacing=\"8\">",
            "                        <Label ",
            "                            Text=\"Tools and technologies\"",
            "                            FontAttributes=\"Bold\"",
            "                            TextColor=\"#334155\"",
            "                        />",
            "                        <Border ",
            "                            BackgroundColor=\"#F8FAFC\"",
            "                            Stroke=\"#CBD5E1\"",
            "                            StrokeShape=\"RoundRectangle 12\"",
            "                            Padding=\"10\"",
            "                            HeightRequest=\"130\"",
            "                        >",
            "                            <CollectionView ",
            "                                ItemsSource=\"{Binding ToolList}\"",
            "                            >",
            "                                <CollectionView.ItemTemplate>",
            "                                    <DataTemplate>",
            "                                        <HorizontalStackLayout Spacing=\"10\">",
            "                                            <CheckBox",
            "                                                IsChecked=\"{Binding IsChecked}\"",
            "                                            />",
            "                                            <Label",
            "                                                Text=\"{Binding Name}\"",
            "                                                VerticalOptions=\"Center\"",
            "                                            />",
            "                                        </HorizontalStackLayout>",
            "                                    </DataTemplate>",
            "                                </CollectionView.ItemTemplate>",
            "                            </CollectionView>",
            "                        </Border>",
            "                    </VerticalStackLayout>",
            "",
            "                    <VerticalStackLayout Spacing=\"8\">",
            "                        <Label ",
            "                            Text=\"Expected salary\"",
            "                            FontAttributes=\"Bold\"",
            "                            TextColor=\"#334155\"",
            "                        />",
            "                        <Border ",
            "                            BackgroundColor=\"#F8FAFC\"",
            "                            Stroke=\"#CBD5E1\"",
            "                            StrokeShape=\"RoundRectangle 12\"",
