    "MAUI Full CRUD Template (XAML + C# Combined)": {
    "scope": "csharp",
    "prefix": "^MAUILIStviewCRUD",
    "body": [
        "/* ===============================",
        "   XAML (MainPage.xaml)",
        "================================",
        "",
        "<ContentPage xmlns=\"http://schemas.microsoft.com/dotnet/2021/maui\"",
        "             xmlns:x=\"http://schemas.microsoft.com/winfx/2009/xaml\"",
        "             x:Class=\"MainPage\">",
        "",
        "    <ScrollView>",
        "        <VerticalStackLayout Padding=\"20\" Spacing=\"10\">",
        "",
        "            <Entry x:Name=\"nazwa\" Placeholder=\"Nazwa\" />",
        "            <Entry x:Name=\"wartosc\" Placeholder=\"Wartość\" Keyboard=\"Numeric\" />",
        "            <Entry x:Name=\"cena\" Placeholder=\"Cena\" Keyboard=\"Numeric\" />",
        "",
        "            <HorizontalStackLayout Spacing=\"10\">",
        "                <Button Text=\"Dodaj\" Clicked=\"Add_Clicked\" />",
        "                <Button x:Name=\"UpdateButton\" Text=\"Edytuj\" IsVisible=\"False\" Clicked=\"Update_Clicked\" />",
        "                <Button x:Name=\"DeleteButton\" Text=\"Usuń\" IsVisible=\"False\" Clicked=\"Delete_Clicked\" />",
        "            </HorizontalStackLayout>",
        "",
        "            <Button Text=\"Raport\" Clicked=\"Raport_Clicked\" />",
        "",
        "            <ListView x:Name=\"ListView\"",
        "                      ItemSelected=\"ListView_ItemSelected\"",
        "                      HeightRequest=\"400\">",
        "                <ListView.ItemTemplate>",
        "                    <DataTemplate>",
        "                        <TextCell Text=\"{Binding}\" />",
        "                    </DataTemplate>",
        "                </ListView.ItemTemplate>",
        "            </ListView>",
        "",
        "        </VerticalStackLayout>",
        "    </ScrollView>",
        "",
        "</ContentPage>",
        "",
        "================================",
        "   C# (MainPage.xaml.cs)",
        "================================*/",
        "",
        "using System.Collections.Generic;",
        "",
        "public partial class MainPage : ContentPage",
        "{",
        "    public List<Item> Lista = new List<Item>();",
        "    public Item wybrany;",
        "",
        "    public MainPage()",
        "    {",
        "        InitializeComponent();",
        "    }",
        "",
        "    public class Item",
        "    {",
        "        public string Nazwa;",
        "        public int Wartosc;",
        "        public float Cena;",
        "",
        "        public override string ToString()",
        "        {",
        "            return $\"{Nazwa} ({Wartosc}) - {Cena} zł\";",
        "        }",
        "    }",
        "",
        "    // ADD",
        "    private void Add_Clicked(object sender, EventArgs e)",
        "    {",
        "        Lista.Add(new Item",
        "        {",
        "            Nazwa = nazwa.Text,",
        "            Wartosc = int.Parse(wartosc.Text),",
        "            Cena = float.Parse(cena.Text)",
        "        });",
        "",
        "        Refresh();",
        "        Clear();",
        "    }",
        "",
        "    // SELECT",
        "    private void ListView_ItemSelected(object sender, SelectedItemChangedEventArgs e)",
        "    {",
        "        if (e.SelectedItem is Item item)",
        "        {",
        "            wybrany = item;",
        "",
        "            nazwa.Text = item.Nazwa;",
        "            wartosc.Text = item.Wartosc.ToString();",
        "            cena.Text = item.Cena.ToString();",
        "",
        "            UpdateButton.IsVisible = true;",
        "            DeleteButton.IsVisible = true;",
        "        }",
        "",
        "        ListView.SelectedItem = null;",
        "    }",
        "",
        "    // UPDATE",
        "    private void Update_Clicked(object sender, EventArgs e)",
        "    {",
        "        wybrany.Nazwa = nazwa.Text;",
        "        wybrany.Wartosc = int.Parse(wartosc.Text);",
        "        wybrany.Cena = float.Parse(cena.Text);",
        "",
        "        Refresh();",
        "        Clear();",
        "",
        "        UpdateButton.IsVisible = false;",
        "        DeleteButton.IsVisible = false;",
        "    }",
        "",
        "    // DELETE",
        "    private void Delete_Clicked(object sender, EventArgs e)",
        "    {",
        "        Lista.Remove(wybrany);",
        "        Refresh();",
        "        Clear();",
        "",
        "        UpdateButton.IsVisible = false;",
        "        DeleteButton.IsVisible = false;",
        "    }",
        "",
        "    // RAPORT",
        "    private void Raport_Clicked(object sender, EventArgs e)",
        "    {",
        "        float suma = 0;",
        "",
        "        foreach (var x in Lista)",
        "            suma += x.Cena;",
        "",
        "        DisplayAlert(\"Raport\", $\"Suma: {suma} zł\", \"OK\");",
        "    }",
        "",
        "    void Refresh()",
        "    {",
        "        ListView.ItemsSource = null;",
        "        ListView.ItemsSource = Lista;",
        "    }",
        "",
        "    void Clear()",
        "    {",
        "        nazwa.Text = \"\";",
        "        wartosc.Text = \"\";",
        "        cena.Text = \"\";",
        "    }",
        "}"
    ],
    "description": "Operacje Listview MAUI - pełny szablon CRUD (XAML + C#)"
    },
        "MAUI Image Simple Change": {
    "scope": "csharp",
    "prefix": "^MAUIimage",
    "body": [
        "<Image x:Name=\"img1\" Source=\"dotnet_bot.png\" WidthRequest=\"150\" HeightRequest=\"150\">",
        "    <Image.GestureRecognizers>",
        "        <TapGestureRecognizer Tapped=\"KlikniecieObrazu\"/>",
        "    </Image.GestureRecognizers>",
        "</Image>",
        "",
        "<Image x:Name=\"img2\" Source=\"new.png\" WidthRequest=\"150\" HeightRequest=\"150\">",
        "    <Image.GestureRecognizers>",
        "        <TapGestureRecognizer Tapped=\"KlikniecieObrazu\"/>",
        "    </Image.GestureRecognizers>",
        "</Image>",
        "",
        "// ZMIANA OBRAZU (assets)",
        "img1.Source = \"new.png\";",
        "",
        "// ZMIANA OBRAZU (plik lokalny)",
        "img2.Source = ImageSource.FromFile(\"C:\\\\images\\\\pic.png\");",
        "",
        "// C# - kliknięcie obrazu",
        "private void KlikniecieObrazu(object sender, TappedEventArgs e)",
        "{",
        "    if(sender is Image img)",
        "    {",
        "        img.Opacity = 0.5;",
        "    }",
        "}"
    ],
    "description": "Obraz MAUI - zmiana obrazu i kliknięcie z przezroczystością"
