"MAUI File Full Operations": {
  "scope": "csharp",
  "prefix": "^MAUIPliki",
  "body": [
    "// OBSŁUGA PLIKÓW W MAUI",
    "using System.IO;",
    "",
    "// ŚCIEŻKA DO PLIKU",
    "string sciezkaPliku = Path.Combine(FileSystem.AppDataDirectory, \"plik.txt\");",
    "",
    "// =========================",
    "// ZAPIS CAŁEGO PLIKU",
    "// =========================",
    "File.WriteAllText(sciezkaPliku, \"Pierwsza linia\");",
    "",
    "// =========================",
    "// DOPISYWANIE TEKSTU",
    "// =========================",
    "File.AppendAllText(sciezkaPliku, \"Nowy tekst\");",
    "",
    "// =========================",
    "// DOPISYWANIE NOWEJ LINII",
    "// =========================",
    "string linia = \"Kolejna linia\";",
    "File.AppendAllText(sciezkaPliku, linia + Environment.NewLine);",
    "",
    "// =========================",
    "// ODCZYT CAŁEGO PLIKU",
    "// =========================",
    "string tekst = File.ReadAllText(sciezkaPliku);",
    "Console.WriteLine(tekst);",
    "",
    "// =========================",
    "// ODCZYT WSZYSTKICH LINII",
    "// =========================",
    "string[] linie = File.ReadAllLines(sciezkaPliku);",
    "",
    "foreach (string item in linie)",
    "{",
    "    Console.WriteLine(item);",
    "}",
    "",
    "// =========================",
    "// SPRAWDZENIE CZY ISTNIEJE",
    "// =========================",
    "bool istnieje = File.Exists(sciezkaPliku);",
    "Console.WriteLine(istnieje);",
    "",
    "// =========================",
    "// USUWANIE PLIKU",
    "// =========================",
    "File.Delete(sciezkaPliku);"
  ],
  "description": "MAUI - pełna obsługa plików: zapis, append, linie, odczyt, delete"
}
    
