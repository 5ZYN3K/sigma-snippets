"CSharp Pattern Search In Text": {
  "scope": "csharp",
  "prefix": "^wyszukiwanieWzorcaWTekscie",
  "body": [
    "// Aby zwrócić index zamiast true/false:",
    "// 1. Zmień 'static bool' na 'static int'",
    "// 2. Zmień 'return true;' na 'return i;' na końcu funkcji",
    "// 3. Zmień 'return false;' na 'return -1;' na końcu funkcji",
    "",
    "static bool ZnajdzWzorzec(string tekst, string wzorzec)",
    "{",
    "    for (int i = 0; i <= tekst.Length - wzorzec.Length; i++)",
    "    {",
    "        bool znaleziono = true;",
    "",
    "        for (int j = 0; j < wzorzec.Length; j++)",
    "        {",
    "            if (tekst[i + j] != wzorzec[j])",
    "            {",
    "                znaleziono = false;",
    "                break;",
    "            }",
    "        }",
    "",
    "        if (znaleziono)",
    "            return true;",
    "    }",
    "",
    "    return false;",
    "}",
    "",
    "// Przykład",
    "string tekst = \"Ala ma kota\";",
    "string wzorzec = \"kot\";",
    "",
    "bool wynik = ZnajdzWzorzec(tekst, wzorzec);",
    "",
    "Console.WriteLine(wynik);"
  ],
  "description": "C# - wyszukiwanie wzorca w tekście bez gotowych funkcji"
}
