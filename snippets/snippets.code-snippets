"Sortowanie Bąbelkowe": {
  "scope": "csharp",
  "prefix": "^sortbabelkowe",
  "body": [
    "//Złożoność: O(n^2)",
    "public int[] BubbleSort(int[] tablica) //dwie pętle, sprawdzenie i zamiana miejscami",
    "{",
    "    for (int i = 0; i < tablica.Length - 1; i++)",
    "    {",
    "        for (int j = 0; j < tablica.Length - 1; j++)",
    "        {",
    "            if (tablica[j] > tablica[j + 1]) //zmienić znak w celu zmiany kolejności sortowania",
    "            {",
    "                //zamiana miejscami elementów",
    "                int tymczasowa = tablica[j];",
    "                tablica[j] = tablica[j + 1];",
    "                tablica[j + 1] = tymczasowa;",
    "            }",
    "        }",
    "    }",
    "",
    "    return tablica;",
    "}"
  ],
  "description": "Sortowanie bąbelkowe"
},
  "Sortowanie Przez Wybor": {
    "scope": "csharp",
    "prefix": "^sortwybor",
    "body": [
      "//Złożoność: O(n^2)",
      "public int[] SortowaniePrzezWybor(int[] tablica) //wyszukiwanie najmniejszego elementu",
      "{",
      "    for (int i = 0; i < tablica.Length - 1; i++)",
      "    {",
      "        int indeksNajmniejszego = i;",
      "",
      "        for (int j = i + 1; j < tablica.Length; j++)",
      "        {",
      "            if (tablica[j] < tablica[indeksNajmniejszego]) //zmienić znak w celu zmiany kolejności sortowania",
      "            {",
      "                indeksNajmniejszego = j;",
      "            }",
      "        }",
      "",
      "        //zamiana miejscami elementów",
      "        int tymczasowa = tablica[i];",
      "        tablica[i] = tablica[indeksNajmniejszego];",
      "        tablica[indeksNajmniejszego] = tymczasowa;",
      "    }",
      "",
      "    return tablica;",
      "}"
    ],
    "description": "Sortowanie przez wybór"
  },

  "Sortowanie Przez Wstawianie": {
    "scope": "csharp",
    "prefix": "^sortwstawianie",
    "body": [
      "//Złożoność: O(n^2)",
      "public int[] SortowaniePrzezWstawianie(int[] tablica) //wstawianie elementu w odpowiednie miejsce",
      "{",
      "    for (int i = 1; i < tablica.Length; i++)",
      "    {",
      "        int aktualnyElement = tablica[i];",
      "        int j = i - 1;",
      "",
      "        while (j >= 0 && tablica[j] > aktualnyElement) //zmienić znak w celu zmiany kolejności sortowania",
      "        {",
      "            //przesuwanie elementów",
      "            tablica[j + 1] = tablica[j];",
      "            j--;",
      "        }",
      "",
      "        //wstawienie elementu",
      "        tablica[j + 1] = aktualnyElement;",
      "    }",
      "",
      "    return tablica;",
      "}"
    ],
    "description": "Sortowanie przez wstawianie"
  },

  "QuickSort": {
    "scope": "csharp",
    "prefix": "^sortquicksort",
    "body": [
      "//Średnia złożoność: O(n log n)",
      "public void QuickSort(int[] tablica, int lewy, int prawy) //sortowanie szybkie z pivotem",
      "{",
      "    int i = lewy;",
      "    int j = prawy;",
      "",
      "    //wybór pivota",
      "    int pivot = tablica[(lewy + prawy) / 2];",
      "",
      "    while (i <= j)",
      "    {",
      "        while (tablica[i] < pivot) //zmienić znak w celu zmiany kolejności sortowania",
      "        {",
      "            i++;",
      "        }",
      "",
      "        while (tablica[j] > pivot) //zmienić znak w celu zmiany kolejności sortowania",
      "        {",
      "            j--;",
      "        }",
      "",
      "        if (i <= j)",
      "        {",
      "            //zamiana miejscami elementów",
      "            int tymczasowa = tablica[i];",
      "            tablica[i] = tablica[j];",
      "            tablica[j] = tymczasowa;",
      "",
      "            i++;",
      "            j--;",
      "        }",
      "    }",
      "",
      "    //rekurencyjne sortowanie lewej części",
      "    if (lewy < j)",
      "    {",
      "        QuickSort(tablica, lewy, j);",
      "    }",
      "",
      "    //rekurencyjne sortowanie prawej części",
      "    if (i < prawy)",
      "    {",
      "        QuickSort(tablica, i, prawy);",
      "    }",
      "}"
    ],
    "description": "Sortowanie szybkie"
  },

  "MergeSort": {
    "scope": "csharp",
    "prefix": "^sortmergesort",
    "body": [
      "//Złożoność: O(n log n)",
      "public void MergeSort(int[] tablica, int lewy, int prawy) //dzielenie tablicy i scalanie",
      "{",
      "    if (lewy < prawy)",
      "    {",
      "        int srodek = (lewy + prawy) / 2;",
      "",
      "        //podział lewej części",
      "        MergeSort(tablica, lewy, srodek);",
      "",
      "        //podział prawej części",
      "        MergeSort(tablica, srodek + 1, prawy);",
      "",
      "        //scalanie tablic",
      "        Scal(tablica, lewy, srodek, prawy);",
      "    }",
      "}",
      "",
      "public void Scal(int[] tablica, int lewy, int srodek, int prawy)",
      "{",
      "    int[] pomocnicza = new int[tablica.Length];",
      "",
      "    int i = lewy;",
      "    int j = srodek + 1;",
      "    int k = lewy;",
      "",
      "    while (i <= srodek && j <= prawy)",
      "    {",
      "        if (tablica[i] < tablica[j]) //zmienić znak w celu zmiany kolejności sortowania",
      "        {",
      "            pomocnicza[k] = tablica[i];",
      "            i++;",
      "        }",
      "        else",
      "        {",
      "            pomocnicza[k] = tablica[j];",
      "            j++;",
      "        }",
      "",
      "        k++;",
      "    }",
      "",
      "    while (i <= srodek)",
      "    {",
      "        pomocnicza[k] = tablica[i];",
      "        i++;",
      "        k++;",
      "    }",
      "",
      "    while (j <= prawy)",
      "    {",
      "        pomocnicza[k] = tablica[j];",
      "        j++;",
      "        k++;",
      "    }",
      "",
      "    for (int x = lewy; x <= prawy; x++)",
      "    {",
      "        tablica[x] = pomocnicza[x];",
      "    }",
      "}"
    ],
    "description": "Sortowanie przez scalanie"
  },
  "BucketSort": {
  "scope": "csharp",
  "prefix": "^sortbucketsort",
  "body": [
    "//Średnia złożoność: O(n + k)",
    "public int[] BucketSort(int[] tablica) //sortowanie kubełkowe",
    "{",
    "    //znalezienie największego elementu",
    "    int maksymalnaWartosc = tablica.Max();",
    "",
    "    //utworzenie kubełków",
    "    List<int>[] kubelki = new List<int>[maksymalnaWartosc + 1];",
    "",
    "    for (int i = 0; i < kubelki.Length; i++)",
    "    {",
    "        kubelki[i] = new List<int>();",
    "    }",
    "",
    "    //przypisanie elementów do kubełków",
    "    for (int i = 0; i < tablica.Length; i++)",
    "    {",
    "        kubelki[tablica[i]].Add(tablica[i]);",
    "    }",
    "",
    "    int indeks = 0;",
    "",
    "    //przepisywanie elementów do tablicy",
    "    for (int i = 0; i < kubelki.Length; i++) //zmień na: for (int i = kubelki.Length - 1; i >= 0; i--) aby sortować malejąco",
    "    {",
    "        foreach (int element in kubelki[i])",
    "        {",
    "            tablica[indeks] = element;",
    "            indeks++;",
    "        }",
    "    }",
    "",
    "    return tablica;",
    "}"
  ],
  "description": "Sortowanie kubełkowe"
},

"Silnia Iteracyjnie": {
    "scope": "csharp",
    "prefix": "^silniaiter",
    "body": [
      "//Złożoność: O(n)",
      "public int SilniaIteracyjnie(int liczba) //silnia przy użyciu pętli",
      "{",
      "    int wynik = 1;",
      "",
      "    for (int i = 1; i <= liczba; i++)",
      "    {",
      "        //mnożenie kolejnych liczb",
