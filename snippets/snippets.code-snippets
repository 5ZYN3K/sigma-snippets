"Szyfr Cezara (pełny, z zawijaniem i ujemnym kluczem)": {
  "scope": "csharp",
  "prefix": "^cezarfull",
  "body": [
    "//Złożoność: O(n)",
    "public string SzyfrCezara(string tekst, int przesuniecie) //szyfrowanie z obsługą ujemnego klucza",
    "{",
    "    if (string.IsNullOrEmpty(tekst))",
    "    {",
    "        return \"\";",
    "    }",
    "",
    "    string wynik = \"\";",
    "",
    "    for (int i = 0; i < tekst.Length; i++)",
    "    {",
    "        char znak = tekst[i];",
    "",
    "        //małe litery",
    "        if (znak >= 'a' && znak <= 'z')",
    "        {",
    "            int przes = (przesuniecie % 26 + 26) % 26; //bezpieczne modulo dla ujemnych",
    "            znak = (char)('a' + (znak - 'a' + przes) % 26);",
    "        }",
    "        //duże litery",
    "        else if (znak >= 'A' && znak <= 'Z')",
    "        {",
    "            int przes = (przesuniecie % 26 + 26) % 26; //bezpieczne modulo dla ujemnych",
    "            znak = (char)('A' + (znak - 'A' + przes) % 26);",
    "        }",
    "",
    "        wynik += znak; //znaki spoza alfabetu bez zmian",
    "    }",
    "",
    "    return wynik;",
    "}"
  ],
