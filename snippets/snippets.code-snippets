"Suma cyfr liczby": {
  "scope": "csharp",
  "prefix": "^sumacyfr",
  "body": [
    "//Złożoność: O(n) gdzie n to liczba cyfr",
    "public int SumaCyfr(int liczba) //oblicza sumę cyfr liczby",
    "{",
    "    int suma = 0;",
    "",
    "    while (liczba != 0)",
    "    {",
    "        //pobranie ostatniej cyfry",
    "        int cyfra = liczba % 10;",
    "",
    "        suma += cyfra;",
    "",
    "        //usunięcie ostatniej cyfry",
    "        liczba = liczba / 10;",
    "    }",
    "",
    "    return suma;",
    "}"
  ],
  "description": "Suma cyfr liczby"
},
