    "// 4. Wybierz projekt z klasami",
    "",
    "using Xunit;",
    "",
    "//==============================",
    "// xUnit - PEŁNY ZESTAW TESTÓW",
    "//==============================",
    "",
    "public class TestyJednostkowe",
    "{",
    "    //==============================",
    "    // 1. TRUE / FALSE",
    "    //==============================",
    "    [Fact]",
    "    public void Test_TrueFalse()",
    "    {",
    "        Assert.True(5 > 3);",
    "        Assert.False(5 < 3);",
    "    }",
    "",
    "    //==============================",
    "    // 2. RÓWNOŚĆ",
    "    //==============================",
    "    [Fact]",
    "    public void Test_Equal()",
    "    {",
    "        Assert.Equal(10, 5 + 5);",
    "    }",
    "",
    "    //==============================",
    "    // 3. NULL / NOT NULL",
    "    //==============================",
    "    [Fact]",
    "    public void Test_Null()",
    "    {",
    "        string tekst = null;",
    "        Assert.Null(tekst);",
    "        Assert.NotNull(\"X\");",
    "    }",
    "",
    "    //==============================",
    "    // 4. WYJĄTKI",
    "    //==============================",
    "    [Fact]",
    "    public void Test_Exception()",
    "    {",
    "        Assert.Throws<DivideByZeroException>(() =>",
    "        {",
