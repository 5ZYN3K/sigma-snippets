"Wyszukiwanie Binarne": {
  "scope": "csharp",
  "prefix": "^wyszukiwaniebinarne",
  "body": [
    "//Złożoność: O(log n)",
    "public int WyszukiwanieBinarne(int[] tablica, int szukana) //wymaga posortowanej tablicy",
    "{",
    "    int lewy = 0;",
    "    int prawy = tablica.Length - 1;",
    "",
    "    while (lewy <= prawy)",
    "    {",
    "        int srodek = (lewy + prawy) / 2;",
    "",
    "        if (tablica[srodek] == szukana)",
    "        {",
    "            return srodek;",
    "        }",
    "",
    "        //szukana większa -> prawa strona",
    "        if (tablica[srodek] < szukana)",
    "        {",
    "            lewy = srodek + 1;",
    "        }",
    "        else",
    "        {",
    "            prawy = srodek - 1;",
    "        }",
    "    }",
    "",
    "    return -1; //nie znaleziono",
    "}"
  ],
  "description": "Wyszukiwanie binarne"
},
"Wyszukiwanie w tablicy z wartownikiem": {
  "scope": "csharp",
  "prefix": "^wyszukiwaniewartownik",
  "body": [
    "//Złożoność: O(n)",
    "public int WyszukiwanieZWartownikiem(int[] tablica, int szukana) //wyszukiwanie liniowe z wartownikiem",
    "{",
    "    int n = tablica.Length;",
    "    int[] pomocnicza = new int[n + 1];",
    "",
    "    //skopiowanie tablicy",
    "    for (int i = 0; i < n; i++)",
    "    {",
    "        pomocnicza[i] = tablica[i];",
    "    }",
    "",
    "    //ustawienie wartownika na końcu",
    "    pomocnicza[n] = szukana;",
    "",
    "    int iIndex = 0;",
    "",
    "    //przeszukiwanie bez sprawdzania granic w pętli",
    "    while (pomocnicza[iIndex] != szukana)",
    "    {",
    "        iIndex++;",
    "    }",
    "",
    "    //sprawdzenie czy znaleziono w oryginalnej tablicy",
    "    if (iIndex < n)",
    "    {",
    "        return iIndex;",
    "    }",
    "",
    "    return -1;",
    "}"
  ],
  "description": "Wyszukiwanie liniowe z wartownikiem"
},
