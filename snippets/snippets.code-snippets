"Operacje na tablicach dwuwymiarowych (INF.04)": {
  "scope": "csharp",
  "prefix": "^tab2d",
  "body": [
    "//TABLICA 2D – podstawy INF.04",
    "",
    "//Deklaracja: int[,] tablica = new int[wiersze, kolumny];",
    "",
    "//Przejście po całej tablicy 2D",
    "//Złożoność: O(n*m)",
    "public void PrzejdzTablice2D(int[,] tablica)",
    "{",
    "    for (int i = 0; i < tablica.GetLength(0); i++) //wiersze",
    "    {",
    "        for (int j = 0; j < tablica.GetLength(1); j++) //kolumny",
    "        {",
    "            Console.Write(tablica[i, j] + \" \");",
    "        }",
    "        Console.WriteLine();",
    "    }",
    "}",
    "",
    "//Suma elementów w 2D",
    "//Złożoność: O(n*m)",
    "public int Suma2D(int[,] tablica)",
    "{",
    "    int suma = 0;",
    "",
    "    for (int i = 0; i < tablica.GetLength(0); i++)",
    "    {",
    "        for (int j = 0; j < tablica.GetLength(1); j++)",
    "        {",
    "            suma += tablica[i, j];",
    "        }",
    "    }",
    "",
    "    return suma;",
    "}",
    "",
    "//Minimum w 2D",
    "public int Min2D(int[,] tablica)",
    "{",
    "    int min = tablica[0, 0];",
    "",
    "    for (int i = 0; i < tablica.GetLength(0); i++)",
    "    {",
    "        for (int j = 0; j < tablica.GetLength(1); j++)",
    "        {",
    "            if (tablica[i, j] < min) //zmień < na > dla maksimum",
    "            {",
    "                min = tablica[i, j];",
    "            }",
    "        }",
    "    }",
    "",
    "    return min;",
    "}",
    "",
    "//Zliczanie elementów spełniających warunek w 2D",
    "public int Zlicz2D(int[,] tablica)",
    "{",
    "    int licznik = 0;",
    "",
    "    for (int i = 0; i < tablica.GetLength(0); i++)",
    "    {",
    "        for (int j = 0; j < tablica.GetLength(1); j++)",
    "        {",
    "            if (tablica[i, j] > 0)",
    "            {",
    "                licznik++;",
    "            }",
    "        }",
    "    }",
    "",
    "    return licznik;",
    "}",
    "",
    "//Zliczanie ile razy wystąpił każdy element",
    "//np. 0 -> 3 razy, 1 -> 5 razy",
    "public void ZliczWystapienia2D(int[,] tablica)",
    "{",
    "    int max = 0;",
    "",
    "    //szukanie największego elementu",
    "    for (int i = 0; i < tablica.GetLength(0); i++)",
    "    {",
    "        for (int j = 0; j < tablica.GetLength(1); j++)",
    "        {",
    "            if (tablica[i, j] > max)",
    "            {",
    "                max = tablica[i, j];",
    "            }",
    "        }",
    "    }",
    "",
    "    int[] wystapienia = new int[max + 1];",
    "",
    "    //zliczanie",
    "    for (int i = 0; i < tablica.GetLength(0); i++)",
    "    {",
    "        for (int j = 0; j < tablica.GetLength(1); j++)",
    "        {",
    "            wystapienia[tablica[i, j]]++;",
    "        }",
    "    }",
    "",
    "    //wyświetlanie",
    "    for (int i = 0; i < wystapienia.Length; i++)",
    "    {",
    "        Console.WriteLine(i + \" -> \" + wystapienia[i]);",
    "    }",
    "}"
  ],
