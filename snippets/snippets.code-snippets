"Maksimum w tablicy": {
  "scope": "csharp",
  "prefix": "^max",
  "body": [
    "//Złożoność: O(n)",
    "public int Maksimum(int[] tablica) //znajduje największy element",
    "{",
    "    int max = tablica[0];",
    "",
    "    for (int i = 1; i < tablica.Length; i++)",
