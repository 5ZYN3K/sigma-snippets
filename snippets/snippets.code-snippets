  "Fibonacci Iteracyjnie": {
    "scope": "csharp",
    "prefix": "^fiboiter",
    "body": [
      "//Złożoność: O(n)",
      "public int FibonacciIteracyjnie(int n) //ciąg Fibonacciego",
      "{",
      "    if (n == 0) return 0;",
      "    if (n == 1) return 1;",
      "",
      "    int a = 0;",
      "    int b = 1;",
