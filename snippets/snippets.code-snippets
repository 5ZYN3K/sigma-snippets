  "prefix": "^oop",
  "body": [
    "//==============================",
    "// PODSTAWY OOP – INF.04",
    "//==============================",
    "",
    "// KLASA BAZOWA (ABSTRAKCYJNA)",
    "public abstract class Zwierze",
    "{",
    "    public string Nazwa { get; set; }",
    "",
    "    public Zwierze(string nazwa)",
    "    {",
    "        Nazwa = nazwa;",
    "    }",
    "",
    "    //metoda abstrakcyjna (MUSI być nadpisana)",
    "    public abstract void WydajDzwiek();",
    "",
    "    //metoda zwykła (dziedziczona)",
    "    public void Spi()",
    "    {",
    "        Console.WriteLine(Nazwa + \" śpi\");",
    "    }",
    "}",
    "",
    "//==============================",
    "// DZIEDZICZENIE",
    "//==============================",
    "",
    "public class Pies : Zwierze",
    "{",
    "    public Pies(string nazwa) : base(nazwa)",
    "    {",
    "    }",
    "",
    "    // NADPISANIE METODY (OVERRIDE)",
    "    public override void WydajDzwiek()",
    "    {",
    "        Console.WriteLine(Nazwa + \": Hau Hau\");",
    "    }",
    "}",
    "",
    "//==============================",
    "// POLIMORFIZM",
    "//==============================",
    "",
    "public void TestPolimorfizm()",
    "{",
    "    Zwierze z1 = new Pies(\"Reksio\");",
    "",
    "    z1.WydajDzwiek(); //wywoła metodę z klasy Pies",
    "    z1.Spi();",
    "}",
    "",
    "//==============================",
    "// INTERFEJS (CZĘSTO NA INF.04)",
    "//==============================",
    "",
    "public interface IPoruszanie",
    "{",
    "    void PoruszajSie();",
    "}",
    "",
    "public class Kot : Zwierze, IPoruszanie",
    "{",
    "    public Kot(string nazwa) : base(nazwa)",
    "    {",
    "    }",
    "",
    "    public override void WydajDzwiek()",
    "    {",
    "        Console.WriteLine(Nazwa + \" Miau\");",
    "    }",
    "",
    "    public void PoruszajSie()",
    "    {",
    "        Console.WriteLine(Nazwa + \" chodzi cicho\");",
    "    }",
    "}",
    "",
    "//==============================",
    "// KLUCZOWE SŁOWA INF.04",
    "//==============================",
    "// abstract – klasa/metoda abstrakcyjna",
    "// override – nadpisanie metody",
    "// virtual – metoda możliwa do nadpisania",
    "// base – odwołanie do klasy bazowej",
    "// interface – kontrakt (co klasa ma robić)"
