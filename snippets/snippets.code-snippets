    "public bool CzyAnagram(string a, string b) //sprawdza czy dwa napisy są anagramami",
    "{",
    "    if (string.IsNullOrEmpty(a) || string.IsNullOrEmpty(b))",
    "    {",
    "        return false;",
    "    }",
    "",
    "    if (a.Length != b.Length)",
    "    {",
    "        return false;",
    "    }",
    "",
    "    char[] tabA = a.ToCharArray();",
    "    char[] tabB = b.ToCharArray();",
    "",
    "    Array.Sort(tabA);",
    "    Array.Sort(tabB);",
    "",
    "    for (int i = 0; i < tabA.Length; i++)",
    "    {",
    "        if (tabA[i] != tabB[i])",
    "        {",
    "            return false;",
    "        }",
    "    }",
    "",
    "    return true;",
    "}"
  ],
  "description": "Sprawdzanie anagramów"
},
