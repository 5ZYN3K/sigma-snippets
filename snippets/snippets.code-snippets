  },
   "NWD": {
    "scope": "csharp",
    "prefix": "^nwd",
    "body": [
      "//Złożoność: O(log n)",
      "public int NWD(int a, int b) //algorytm Euklidesa",
      "{",
      "    while (b != 0)",
      "    {",
      "        //reszta z dzielenia",
      "        int reszta = a % b;",
      "",
      "        a = b;",
      "        b = reszta;",
      "    }",
      "",
      "    return a;",
      "}"
    ],
    "description": "Największy wspólny dzielnik"
  },

