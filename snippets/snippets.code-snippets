"Gettery i settery + metody": {
  "scope": "csharp",
  "prefix": "^funkcjegetset",
  "body": [
    "//==============================",
    "// GETTERY I SETTERY",
    "//==============================",
    "",
    "class Osoba",
    "{",
    "    //==============================",
    "    // POLA (PRYWATNE)",
    "    //==============================",
    "    private string imie;",
    "    private int wiek;",
    "",
    "    //==============================",
    "    // SETTER (metoda ustawiająca)",
    "    //==============================",
    "    public void SetImie(string value)",
    "    {",
    "        imie = value;",
    "    }",
    "",
    "    //==============================",
    "    // GETTER (metoda pobierająca)",
    "    //==============================",
    "    public string GetImie()",
    "    {",
    "        return imie;",
    "    }",
    "",
    "    //==============================",
    "    // SETTER (wiek)",
    "    //==============================",
    "    public void SetWiek(int value)",
    "    {",
    "        wiek = value;",
    "    }",
    "",
    "    //==============================",
    "    // GETTER (wiek)",
    "    //==============================",
    "    public int GetWiek()",
    "    {",
    "        return wiek;",
    "    }",
    "",
    "    //==============================",
    "    // FUNKCJA DZIAŁAJĄCA JAK GETTER",
    "    //==============================",
    "    public string PobierzDane()",
    "    {",
    "        return imie + \" \" + wiek;",
    "    }",
    "",
    "    //==============================",
    "    // FUNKCJA DZIAŁAJĄCA JAK SETTER",
    "    //==============================",
    "    public void UstawDane(string nowyImie, int nowyWiek)",
    "    {",
    "        imie = nowyImie;",
    "        wiek = nowyWiek;",
    "    }",
    "}"
  ],
  "description": "Gettery, settery i metody działające jak get/set"
},
